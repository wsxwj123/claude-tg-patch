# Fish Audio S2 TTS API key — required for voice replies
# Get yours at https://fish.audio
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here

# Telegram bot token — required for sendVoice (voice-bridge calls Telegram directly,
# not via the official plugin)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: HTTP proxy if your network needs one to reach fish.audio / telegram
# HTTPS_PROXY=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897
NO_PROXY=127.0.0.1,localhost

# Port the local HTTP bridge listens on (default 7788)
# VOICE_BRIDGE_PORT=7788
